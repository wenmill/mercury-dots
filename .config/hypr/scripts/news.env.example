# Copy to ~/.config/hypr/news.env and fill in, then: chmod 600 ~/.config/hypr/news.env
# These credentials let news_fetch.py read your FreshRSS via its Google Reader API.

FRESHRSS_URL=http://127.0.0.1:8110
FRESHRSS_USER=changeme
# FreshRSS ▸ Settings ▸ Profile ▸ "API password" (NOT your website login password).
FRESHRSS_API_PASSWORD=changeme
# Optional: how many recent articles to keep in the cache.
NEWS_LIMIT=40
