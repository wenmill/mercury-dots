#!/usr/bin/env bash
# movcli backend — movies & TV via mov-cli (headless, auto-first result, and the
# only backend that hits an EXACT TV episode via `-ep ep:season`).
#
# Backend contract (see backends/README.md):
#   capabilities            -> the kinds this backend serves
#   play <kind> <title> [s] [e]  -> play into the PiP; EXIT NON-ZERO on failure
#   browse <kind> [query]   -> interactive browse into the PiP
set -uo pipefail
: "${VIDEO_DIR:=$(cd "$(dirname "$0")/.." && pwd)}"
source "$VIDEO_DIR/lib/common.sh"

# Prefer the isolated uv-tool mov-cli over a system one.
MOVCLI="$HOME/.local/bin/mov-cli"; [ -x "$MOVCLI" ] || MOVCLI="mov-cli"

verb="${1:-}"; kind="${2:-}"; shift 2 2>/dev/null || true
case "$verb" in
    capabilities) echo "movie tv" ;;
    play)
        command -v "$MOVCLI" >/dev/null 2>&1 || { vlog "movcli: not installed"; exit 1; }
        title="${1:?title required}"
        if [ "$kind" = "tv" ]; then
            season="${2:-1}"; ep="${3:-1}"
            vlog "movcli tv :: $title s$season e$ep"
            vid_run_checked 'there was no results|no results|no such' \
                "$MOVCLI" -c 1 -ep "${ep}:${season}" --player mpv "$title"   # mov-cli order = episode:season
        else
            vlog "movcli movie :: $title"
            vid_run_checked 'there was no results|no results|no such' \
                "$MOVCLI" -c 1 --player mpv "$title"
        fi
        ;;
    browse) exec bash "$PIP_DIR/pip_movcli.sh" "$@" ;;
    *) exit 2 ;;
esac
