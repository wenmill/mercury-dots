#!/usr/bin/env bash
# anime provider — thin dispatcher to the selected backend.
# Backend chosen by config.json "anime_backend" (default: anicli). Add your own
# source in ../backends/ (e.g. a Jellyfin anime library) — see its README.
set -uo pipefail
: "${VIDEO_DIR:=$(cd "$(dirname "$0")/.." && pwd)}"
source "$VIDEO_DIR/lib/common.sh"

verb="${1:-}"; shift 2>/dev/null || true
case "$verb" in
    capabilities) echo "play browse" ;;
    play)    vid_dispatch anime play "$@" ;;   # "$@" = <title> [ep]
    browse)  vid_dispatch anime browse "$@" ;;
    resolve) echo "anime: resolve unsupported (backend resolves internally)" >&2; exit 1 ;;
    *) echo "anime: unknown verb '$verb'" >&2; exit 2 ;;
esac
