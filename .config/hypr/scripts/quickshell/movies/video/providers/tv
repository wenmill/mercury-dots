#!/usr/bin/env bash
# tv provider — thin dispatcher to the selected backend.
# Backend chosen by config.json "tv_backend" (default chain: lobster → torrentio).
# lobster defers anything but S1E1 headlessly, so exact episodes fall through to
# torrentio (needs a debrid account). Add your own source in ../backends/.
set -uo pipefail
: "${VIDEO_DIR:=$(cd "$(dirname "$0")/.." && pwd)}"
source "$VIDEO_DIR/lib/common.sh"

verb="${1:-}"; shift 2>/dev/null || true
case "$verb" in
    capabilities) echo "play browse download" ;;
    play)     vid_dispatch tv play "$@" ;;
    download) vid_dispatch tv download "$@" ;;      # "$@" = <title> [season] [ep]
    browse)  vid_dispatch tv browse "$@" ;;
    resolve) echo "tv: resolve unsupported (backend resolves internally)" >&2; exit 1 ;;
    *) echo "tv: unknown verb '$verb'" >&2; exit 2 ;;
esac
