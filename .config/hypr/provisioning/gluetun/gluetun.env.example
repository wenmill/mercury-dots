# Gluetun VPN credentials — fill in for YOUR provider, then:
#   systemctl --user daemon-reload && systemctl --user start gluetun
# Full provider list + variables:
#   https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
#
# ── Example: any WireGuard provider (Mullvad, ProtonVPN, AirVPN, custom…) ──
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=<your-wg-private-key>
# WIREGUARD_ADDRESSES=<your-wg-address, e.g. 10.x.x.x/32>
# SERVER_CITIES=Amsterdam
#
# ── Example: OpenVPN with username/password (NordVPN, PIA, Surfshark…) ──
# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=openvpn
# OPENVPN_USER=<user>
# OPENVPN_PASSWORD=<pass>
# SERVER_COUNTRIES=Netherlands
#
# ── Example: bring-your-own WireGuard config ──
# VPN_SERVICE_PROVIDER=custom
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=...
# WIREGUARD_PUBLIC_KEY=...   (the server's)
# WIREGUARD_ADDRESSES=...
# VPN_ENDPOINT_IP=...
# VPN_ENDPOINT_PORT=51820
