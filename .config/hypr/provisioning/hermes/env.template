# ~/.hermes/.env — Hermes gateway environment.
# Non-secret hosts/flags are checked in; every secret is generated per-machine
# by install.sh (provision_hermes) and appended below this block. This file is
# 0600 and must NEVER be committed with real secret values.

# ── HTTP API server (the widgets talk to this) ───────────────────────────────
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
# API_SERVER_KEY is generated per-machine and also stored in the keyring as
# `hermes_token` so the Quickshell widgets authenticate with the same value.

# ── autobrowse MCP (stealth browser) ─────────────────────────────────────────
# MCP_AUTOBROWSE_API_KEY is generated per-machine to MATCH the autobrowse
# container's AUTH_TOKEN (autobrowse.container).

# ── optional service hosts (harmless if the service is down) ─────────────────
SEARXNG_URL=http://localhost:8888
HONCHO_BASE_URL=http://localhost:8000

# ── local LLM (llama-server ignores the key value) ───────────────────────────
OPENAI_API_KEY=sk-local-llama
